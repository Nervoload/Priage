/// backend/prisma/schema.prisma
// Prisma schema file
// John Surette
// Date Created: Dec 8 2025
// Last Modified: Jan 14 2026
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum EncounterStatus {
  // Patient-facing
  EXPECTED                 // Patient registered but not yet arrived
  ADMITTED                 // Patient has arrived and is admitted
  // In Hospital
  TRIAGE                   // Patient is in triage process  
  WAITING                  // Patient is waiting to be examined by medical staff
  
  // Terminal Status
  COMPLETE                 // Patient has been seen and treatment is complete  
  UNRESOLVED               // Patient left before completion
  CANCELLED                // Encounter was cancelled 
} 

enum Role { 
  ADMIN
  NURSE
  STAFF
  DOCTOR
}


enum SenderType { # Needs more work...
  PATIENT
  USER
  SYSTEM
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AssetKind {
  IMAGE
}

enum AssetContext {
  INTAKE_IMAGE
  MESSAGE_ATTACHMENT
}

enum AssetStatus {
  READY
  DELETED
}

enum LogRecordLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum EventType {
  // Inbound patient events
  ENCOUNTER_CREATED
  ARRIVAL_TIMEOUT
  STATUS_CHANGE

  MESSAGE_CREATED
  MESSAGE_READ
  MESSAGE_TRANSLATED

  // Triage events
  TRIAGE_CREATED
  TRIAGE_NOTE_ADDED
  TRIAGE_NOTE_UPDATED
  TRIAGE_COMPLETED

  // Outbound patient events
  ALERT_CREATED
  ALERT_ACKNOWLEDGED
  ALERT_RESOLVED
}

enum IntakeSessionStatus {
  DRAFT
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum ContextSourceType {
  PATIENT
  PARTNER
  INSTITUTION
  AI
}

enum TrustTier {
  UNTRUSTED
  PARTNER_SUBMITTED
  INSTITUTION_TRUSTED
}

enum ReviewState {
  UNREVIEWED
  PATIENT_CONFIRMED
  STAFF_REVIEWED
  REJECTED
}

enum VisibilityScope {
  STORED_ONLY
  ADMISSIONS
  TRIAGE
  CLINICAL
}

enum SummaryProjectionKind {
  OPERATIONAL
  AI_DERIVED
  HUMAN_REVIEWED
}

enum PartnerCredentialStatus {
  ACTIVE
  DISABLED
}

enum IdempotencyRecordStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum WebhookSubscriptionStatus {
  ACTIVE
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

model Encounter {
  id        Int      @id @default(autoincrement())
  publicId  String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    EncounterStatus @default(EXPECTED)
  chiefComplaint String?
  details        String?

  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  hospitalId Int
  patient   PatientProfile @relation(fields: [patientId], references: [id])
  patientId Int

  currentTriageId Int? @unique
  currentTriage TriageAssessment? @relation("current_triage", fields: [currentTriageId], references: [id])


  currentCtasLevel    Int? // 1 (highest acuity) ... 5 (lowest)
  currentPriorityScore Int? // higher = sooner, your own scalar


  // Pipeline timestamps (denormalized for fast UI queries)
  expectedAt DateTime? @default(now())
  arrivedAt   DateTime?
  triagedAt   DateTime?
  waitingAt   DateTime?
  seenAt      DateTime?
  departedAt  DateTime?
  cancelledAt DateTime?

  triageAssessments TriageAssessment[]
  messages          Message[]
  events            EncounterEvent[]
  alerts            Alert[]
  assets            Asset[]
  patientSessions   PatientSession[]
  intakeSessions    IntakeSession[]
  contextItems      ContextItem[]
  summaryProjections SummaryProjection[]
  partnerReferences PartnerReference[]
  commandResults    CommandResult[]
  readCursors       EncounterReadCursor[]


  // Tenant-hardening: enables compound FKs from child tables
  @@unique([id, hospitalId])

  // Indices for common views
  @@index([hospitalId, status])
  @@index([hospitalId, updatedAt])
  @@index([hospitalId, currentPriorityScore, updatedAt])
  @@index([patientId, createdAt])

}

model EncounterEvent {
  id        Int      @id @default(autoincrement())
  type      EventType
  metadata  Json?
  createdAt DateTime @default(now())

  actorUserId    Int?
  actorPatientId Int?

  // Optional “outbox processing” 
  processedAt DateTime?

  // Tenant-safe encounter link
  encounterId Int
  hospitalId  Int
  encounter   Encounter @relation(fields: [encounterId, hospitalId], references: [id, hospitalId], onDelete: Cascade)

  @@index([encounterId, createdAt])
  @@index([hospitalId, createdAt])
  @@index([processedAt])
}

//---------------------------------------------------------------------//
//                    HOSPITAL-SIDE SCHEMA 
//---------------------------------------------------------------------//
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  hospitalId Int

  triageAssessments TriageAssessment[]
  messages          Message[]
  acknowledgedAlerts Alert[] @relation("alert_ack_by")
  resolvedAlerts     Alert[] @relation("alert_resolve_by")
  readCursors        EncounterReadCursor[]
  assets             Asset[]

  @@unique([hospitalId, email])
  @@index([hospitalId, role])
}

model Hospital {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  users      User[]
  encounters Encounter[]
  intakeSessions IntakeSession[]
  contextItems ContextItem[]
  partnerCredentials PartnerCredential[]
  webhookSubscriptions WebhookSubscription[]
  config     HospitalConfig?

  @@index([slug])
}

model HospitalConfig {
  hospitalId Int     @id
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  // Keep it flexible early; later you can normalize specific fields.
  config Json

  updatedAt DateTime @updatedAt
}

model TriageAssessment {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) // assessedAt; name it however you like

  // Versioned triage assessment
  ctasLevel     Int // 1 highest ... 5 lowest
  priorityScore Int
  chiefComplaint String?
  painLevel     Int?       // 0–10 scale
  vitalSigns    Json?      // { bloodPressure, heartRate, temperature, respiratoryRate, oxygenSaturation }
  note          String?

  createdByUserId Int
  createdBy      User @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)

  // Tenant-safe encounter link (compound FK)
  encounterId Int
  hospitalId  Int
  encounter   Encounter @relation(fields: [encounterId, hospitalId], references: [id, hospitalId], onDelete: Cascade)
  
  // Backlink for "current triage"
  currentOf Encounter? @relation("current_triage")

  @@index([encounterId, createdAt])
  @@index([hospitalId, createdAt])
}

model Alert {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  type     String
  severity AlertSeverity @default(MEDIUM)

  acknowledgedAt DateTime?
  acknowledgedByUserId Int?
  acknowledgedByUser   User? @relation("alert_ack_by", fields: [acknowledgedByUserId], references: [id], onDelete: Restrict)

  resolvedAt DateTime?
  resolvedByUserId Int?
  resolvedByUser   User? @relation("alert_resolve_by", fields: [resolvedByUserId], references: [id], onDelete: Restrict)

  metadata Json?

  // Tenant-safe encounter link
  encounterId Int
  hospitalId  Int
  encounter   Encounter @relation(fields: [encounterId, hospitalId], references: [id, hospitalId], onDelete: Cascade)

  @@index([hospitalId, createdAt])
  @@index([encounterId, createdAt])
  @@index([hospitalId, acknowledgedAt])
  @@index([hospitalId, resolvedAt])
}

//---------------------------------------------------------------------//
//                    PATIENT-SIDE SCHEMA 
//---------------------------------------------------------------------//
model PatientProfile {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // Profile details

  firstName         String?
  lastName          String?
  phone             String?
  age               Int?
  gender            String?
  heightCm          Int?
  weightKg          Int?
  allergies         String?
  conditions        String?
  preferredLanguage String  @default("en")

  optionalHealthInfo Json?

  encounters Encounter[]
  messages   Message[]
  patientSessions PatientSession[]
  intakeSessions IntakeSession[]
  contextItems ContextItem[]
  readCursors EncounterReadCursor[]
  assets      Asset[]

}

model PatientSession {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?

  patientId Int
  patient   PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)

  encounterId Int?
  encounter   Encounter? @relation(fields: [encounterId], references: [id], onDelete: Cascade)
  intakeSessions IntakeSession[]
  assets      Asset[]

  @@index([patientId, createdAt])
  @@index([encounterId, createdAt])
  @@index([expiresAt])
}

model IntakeSession {
  id        Int                 @id @default(autoincrement())
  publicId  String              @unique
  status    IntakeSessionStatus @default(DRAFT)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  expiresAt DateTime?
  confirmedAt DateTime?
  cancelledAt DateTime?

  patientId Int?
  patient   PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  hospitalId Int?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)

  encounterId Int?
  encounter   Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)

  authSessionId Int?
  authSession   PatientSession? @relation(fields: [authSessionId], references: [id], onDelete: SetNull)

  contextItems ContextItem[]
  assets       Asset[]
  summaries    SummaryProjection[]
  partnerReferences PartnerReference[]
  commandResults CommandResult[]

  @@index([patientId, createdAt])
  @@index([hospitalId, createdAt])
  @@index([encounterId, createdAt])
  @@index([status, createdAt])
  @@index([authSessionId, status, createdAt])
}

model EncounterReadCursor {
  id                Int      @id @default(autoincrement())
  encounterId       Int
  hospitalId        Int
  userId            Int?
  patientId         Int?
  lastReadMessageId Int?
  lastReadAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  encounter Encounter       @relation(fields: [encounterId, hospitalId], references: [id, hospitalId], onDelete: Cascade)
  user      User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient   PatientProfile? @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([encounterId, hospitalId])
  @@unique([encounterId, userId])
  @@unique([encounterId, patientId])
}

model Message {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  senderType SenderType

  // Exactly one of these should be set for non-system messages (enforce in app logic)
  createdByUserId    Int?
  createdByUser      User? @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdByPatientId Int?
  createdByPatient   PatientProfile? @relation(fields: [createdByPatientId], references: [id], onDelete: Restrict)

  content  String
  original String?
  language String?

  // Tenant-safe encounter link
  encounterId Int
  hospitalId  Int
  encounter   Encounter @relation(fields: [encounterId, hospitalId], references: [id, hospitalId], onDelete: Cascade)

  // Optional future-proofing
  isInternal Boolean @default(false)
  assets     Asset[]

  @@index([encounterId, createdAt])
  @@index([hospitalId, createdAt])
}

model Asset {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Store pointers/metadata, not the binary.
  kind             AssetKind    @default(IMAGE)
  context          AssetContext
  status           AssetStatus  @default(READY)
  storageKey       String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  width            Int?
  height           Int?
  sha256     String?

  // Tenant-safe encounter link. Intake uploads can exist before an encounter is created.
  encounterId Int?
  hospitalId  Int?
  encounter   Encounter? @relation(fields: [encounterId, hospitalId], references: [id, hospitalId], onDelete: Cascade)

  patientSessionId Int?
  patientSession   PatientSession? @relation(fields: [patientSessionId], references: [id], onDelete: Cascade)

  intakeSessionId Int?
  intakeSession   IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)

  messageId Int?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: SetNull)

  createdByUserId Int?
  createdByUser   User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdByPatientId Int?
  createdByPatient   PatientProfile? @relation(fields: [createdByPatientId], references: [id], onDelete: SetNull)

  @@index([encounterId, createdAt])
  @@index([hospitalId, createdAt])
  @@index([patientSessionId, createdAt])
  @@index([intakeSessionId, createdAt])
  @@index([messageId, createdAt])
  @@index([status])
  @@index([context])
}

model ContextItem {
  id        Int              @id @default(autoincrement())
  publicId  String           @unique
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  itemType  String
  schemaVersion String       @default("v1")
  payload   Json

  sourceType      ContextSourceType
  trustTier       TrustTier
  reviewState     ReviewState
  visibilityScope VisibilityScope

  hospitalId Int?
  hospital   Hospital? @relation(fields: [hospitalId], references: [id], onDelete: SetNull)

  patientId Int?
  patient   PatientProfile? @relation(fields: [patientId], references: [id], onDelete: SetNull)

  intakeSessionId Int?
  intakeSession   IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)

  encounterId Int?
  encounter   Encounter? @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  partnerId Int?
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  supersedesId Int?
  supersedes   ContextItem? @relation("context_item_supersession", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy ContextItem[] @relation("context_item_supersession")

  @@index([intakeSessionId, createdAt])
  @@index([encounterId, createdAt])
  @@index([hospitalId, createdAt])
  @@index([patientId, createdAt])
  @@index([partnerId, createdAt])
}

model SummaryProjection {
  id        Int                   @id @default(autoincrement())
  publicId  String                @unique
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  kind      SummaryProjectionKind
  content   Json
  active    Boolean               @default(true)

  sourceType      ContextSourceType
  trustTier       TrustTier
  reviewState     ReviewState
  visibilityScope VisibilityScope

  intakeSessionId Int?
  intakeSession   IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)

  encounterId Int?
  encounter   Encounter? @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@index([intakeSessionId, createdAt])
  @@index([encounterId, createdAt])
  @@index([kind, createdAt])
}

model Partner {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  slug      String   @unique

  credentials PartnerCredential[]
  references  PartnerReference[]
  contextItems ContextItem[]

  @@index([slug])
}

model PartnerCredential {
  id        Int                     @id @default(autoincrement())
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  label     String
  keyPrefix String
  keyHash   String                  @unique
  scopes    String[]
  status    PartnerCredentialStatus @default(ACTIVE)

  partnerId Int
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  hospitalId Int
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  trustPolicy PartnerTrustPolicy?
  idempotencyRecords IdempotencyRecord[]
  commandResults      CommandResult[]
  webhookSubscriptions WebhookSubscription[]

  @@index([partnerId, createdAt])
  @@index([hospitalId, createdAt])
}

model PartnerTrustPolicy {
  id        Int             @id @default(autoincrement())
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  partnerCredentialId Int  @unique
  partnerCredential   PartnerCredential @relation(fields: [partnerCredentialId], references: [id], onDelete: Cascade)

  defaultTrustTier              TrustTier       @default(PARTNER_SUBMITTED)
  defaultVisibilityScope        VisibilityScope @default(STORED_ONLY)
  requirePatientConfirmation    Boolean         @default(true)
  allowPreConfirmOperationalUse Boolean         @default(false)
}

model PartnerReference {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  referenceType  String
  referenceValue String

  partnerId Int
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  intakeSessionId Int?
  intakeSession   IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: Cascade)

  encounterId Int?
  encounter   Encounter? @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  @@unique([partnerId, referenceType, referenceValue])
  @@index([intakeSessionId, createdAt])
  @@index([encounterId, createdAt])
}

model CommandResult {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  command   String
  requestFingerprint String
  responseStatus Int
  responseBody Json

  partnerCredentialId Int
  partnerCredential   PartnerCredential @relation(fields: [partnerCredentialId], references: [id], onDelete: Cascade)

  intakeSessionId Int?
  intakeSession   IntakeSession? @relation(fields: [intakeSessionId], references: [id], onDelete: SetNull)

  encounterId Int?
  encounter   Encounter? @relation(fields: [encounterId], references: [id], onDelete: SetNull)

  idempotencyRecords IdempotencyRecord[]

  @@index([partnerCredentialId, createdAt])
  @@index([intakeSessionId, createdAt])
  @@index([encounterId, createdAt])
}

model IdempotencyRecord {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  command   String
  idempotencyKey String
  requestFingerprint String
  status    IdempotencyRecordStatus @default(IN_PROGRESS)
  completedAt DateTime?

  partnerCredentialId Int
  partnerCredential   PartnerCredential @relation(fields: [partnerCredentialId], references: [id], onDelete: Cascade)

  commandResultId Int?
  commandResult   CommandResult? @relation(fields: [commandResultId], references: [id], onDelete: Cascade)

  @@unique([partnerCredentialId, command, idempotencyKey])
  @@index([commandResultId])
}

model WebhookSubscription {
  id        Int                       @id @default(autoincrement())
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  targetUrl String
  status    WebhookSubscriptionStatus @default(ACTIVE)
  eventTypes String[]
  secretHash String

  hospitalId Int
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  partnerCredentialId Int?
  partnerCredential   PartnerCredential? @relation(fields: [partnerCredentialId], references: [id], onDelete: SetNull)

  deliveries WebhookDelivery[]

  @@index([hospitalId, createdAt])
  @@index([partnerCredentialId, createdAt])
}

model WebhookDelivery {
  id        Int                   @id @default(autoincrement())
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  status    WebhookDeliveryStatus @default(PENDING)
  eventType String
  payload   Json
  attempts  Int                   @default(0)
  deliveredAt DateTime?
  lastAttemptAt DateTime?
  lastError String?

  webhookSubscriptionId Int
  webhookSubscription   WebhookSubscription @relation(fields: [webhookSubscriptionId], references: [id], onDelete: Cascade)

  @@index([webhookSubscriptionId, createdAt])
  @@index([status, createdAt])
}

model LogRecord {
  id            Int            @id @default(autoincrement())
  createdAt     DateTime       @default(now())
  level         LogRecordLevel
  message       String
  correlationId String?
  service       String
  operation     String
  userId        Int?
  patientId     Int?
  hospitalId    Int?
  encounterId   Int?
  data          Json?
  errorMessage  String?
  errorStack    String?
  errorCode     String?

  @@index([createdAt])
  @@index([level, createdAt])
  @@index([correlationId, createdAt])
  @@index([service, operation, createdAt])
  @@index([hospitalId, createdAt])
  @@index([encounterId, createdAt])
  @@index([userId, createdAt])
  @@index([patientId, createdAt])
}

model ErrorReportSnapshot {
  id              Int      @id @default(autoincrement())
  reportId        String   @unique
  correlationId   String
  generatedAt     DateTime @default(now())
  summary         String
  errorCount      Int
  logCount        Int
  payload         Json
  createdByUserId Int?

  @@index([correlationId, generatedAt])
  @@index([generatedAt])
}
