# Priage Backend — environment variables
# Copy this to .env and adjust values for your setup.
# Credentials here are for LOCAL DEVELOPMENT ONLY.

# ─── Database (matches docker-compose.yml) ────────────────────────────────────
DATABASE_URL="postgresql://priage:priage@localhost:5432/priage?schema=public"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# IMPORTANT: In production, set a strong random secret (32+ chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="priage-dev-secret-change-in-production"
STAFF_AUTH_TTL_MS=28800000
PATIENT_SESSION_TTL_MS=86400000
AUTH_COOKIE_SAME_SITE="lax"
# Optional for subdomain deployments such as api.priage.ca ←→ patient.priage.ca
# AUTH_COOKIE_DOMAIN=".priage.ca"

# ─── Demo Access Gate ─────────────────────────────────────────────────────────
# When set, every request (except /health and /demo-access) requires a valid
# priage_demo_access cookie. POST /demo-access { code: "..." } sets the cookie.
# Leave unset for local dev (gate is disabled).
# Generate one: node -e "console.log(require('crypto').randomBytes(12).toString('base64url'))"
#DEMO_ACCESS_CODE=1234567890abcdef

# ─── Server ───────────────────────────────────────────────────────────────────
# In production, set NODE_ENV=production to enable secure cookies, strict CORS,
# and tighter rate limits.
# NODE_ENV=production
PORT=3000
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"
# In non-production, loopback requests (localhost/127.0.0.1/::1) skip throttling
# by default so local frontend testing and ./priage-dev test do not poison the same
# in-memory IP bucket. Set to false to exercise throttling locally.
# THROTTLE_SKIP_LOOPBACK=true

# ─── Redis (matches docker-compose.yml) ──────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL="log"

# ─── Jobs ─────────────────────────────────────────────────────────────────────
TRIAGE_REASSESSMENT_MINUTES=30

# ─── App Info ─────────────────────────────────────────────────────────────────
APP_VERSION="0.1.0"

# ─── Triage Interview AI Proxy ────────────────────────────────────────────────
TRIAGE_AI_API_KEY=
TRIAGE_AI_MODEL="gpt-5-mini"
TRIAGE_AI_BASE_URL="https://api.openai.com/v1"
TRIAGE_AI_TIMEOUT_MS=12000
TRIAGE_AI_PROMPT_VERSION="v2"
# Optional for GPT-5-style reasoning models: low, medium, or high
# TRIAGE_AI_REASONING_EFFORT="low"
# Optional structured-output ceiling
# TRIAGE_AI_MAX_OUTPUT_TOKENS=1400
