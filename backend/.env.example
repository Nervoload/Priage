# Priage Backend — environment variables
# Copy this to .env and adjust values for your setup.
# Credentials here are for LOCAL DEVELOPMENT ONLY.

# ─── Database (matches docker-compose.yml) ────────────────────────────────────
DATABASE_URL="postgresql://priage:priage@localhost:5432/priage?schema=public"
DATABASE_PROXY_MODE=direct
DATABASE_APPLICATION_NAME=priage-backend-dev
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=20
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=2000
DATABASE_POOL_MAX_LIFETIME_SECONDS=300
DATABASE_POOL_STATEMENT_TIMEOUT_MS=15000
DATABASE_POOL_QUERY_TIMEOUT_MS=20000
DATABASE_CONNECTION_ATTEMPTS=3

# ─── Auth ─────────────────────────────────────────────────────────────────────
# IMPORTANT: In production, set a strong random secret (32+ chars).
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET="priage-dev-secret-change-in-production"
STAFF_AUTH_TTL_MS=28800000
PATIENT_SESSION_TTL_MS=86400000
ALLOW_PATIENT_TOKEN_HEADER=false
ALLOW_LEGACY_RAW_PATIENT_TOKENS=false
AUTH_COOKIE_SAME_SITE="lax"
# Optional for subdomain deployments such as api.priage.ca ←→ patient.priage.ca
# AUTH_COOKIE_DOMAIN=".priage.ca"

# ─── Demo Access Gate ─────────────────────────────────────────────────────────
# When set, every request (except /health and /demo-access) requires a valid
# priage_demo_access cookie. POST /demo-access { code: "..." } sets the cookie.
# Leave unset for local dev (gate is disabled).
# Generate one: node -e "console.log(require('crypto').randomBytes(12).toString('base64url'))"
#DEMO_ACCESS_CODE=1234567890abcdef

# ─── Server ───────────────────────────────────────────────────────────────────
# In production, set NODE_ENV=production to enable secure cookies, strict CORS,
# and tighter rate limits.
# NODE_ENV=production
PORT=3000
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"
# In non-production, loopback requests (localhost/127.0.0.1/::1) skip throttling
# by default so local frontend testing and ./priage-dev test do not poison the same
# in-memory IP bucket. Set to false to exercise throttling locally.
# THROTTLE_SKIP_LOOPBACK=true

# ─── Redis (matches docker-compose.yml) ──────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_SERVERNAME=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL="log"

# ─── Jobs ─────────────────────────────────────────────────────────────────────
TRIAGE_REASSESSMENT_MINUTES=30

# ─── App Info ─────────────────────────────────────────────────────────────────
APP_VERSION="0.1.0"

# ─── Triage Interview AI Proxy ────────────────────────────────────────────────
TRIAGE_AI_API_KEY=
TRIAGE_AI_MODEL="gpt-5-mini"
TRIAGE_AI_BASE_URL="https://api.openai.com/v1"
TRIAGE_AI_TIMEOUT_MS=12000
TRIAGE_AI_PROMPT_VERSION="v2"
# Optional for GPT-5-style reasoning models: low, medium, or high
# TRIAGE_AI_REASONING_EFFORT="low"
# Optional structured-output ceiling
# TRIAGE_AI_MAX_OUTPUT_TOKENS=1400
# Production edge and request protection
GATEWAY_SHARED_SECRET=
EDGE_PUBLIC_AUTH_LIMIT=30
EDGE_DIRECTORY_LIMIT=120
EDGE_WRITE_LIMIT=120
EDGE_GLOBAL_LIMIT=600
EDGE_TOKEN_ATTEMPT_LIMIT=300
REQUEST_JSON_LIMIT=1mb
REQUEST_FORM_LIMIT=256kb
SOCKET_CONNECTION_ATTEMPTS_PER_MINUTE=30
SOCKET_CONNECTIONS_PER_USER=5
SOCKET_CONNECTION_STALE_MS=120000
SOCKET_ENCOUNTER_SUBSCRIPTION_CAP=250
PATIENT_SSE_CONNECTIONS_PER_PATIENT=3
PATIENT_SSE_CONNECTION_STALE_MS=90000

# Staff identity and clinical access
STAFF_MFA_REQUIRED=false
STAFF_MFA_ENCRYPTION_KEY=
STAFF_MFA_ISSUER=Priage
STAFF_DEVICE_BINDING_REQUIRED=false
STAFF_MAX_ACTIVE_SESSIONS=5
STAFF_SESSION_IDLE_TIMEOUT_MS=1800000
SSO_JWT_PUBLIC_KEY=
SSO_JWT_ISSUER=
SSO_JWT_AUDIENCE=
SSO_ALLOW_EMAIL_LINK=false
CARE_TEAM_ACCESS_REQUIRED=false
SENSITIVE_READ_AUDIT_FAIL_CLOSED=false

# Durable patient writes and event dispatch
PATIENT_IDEMPOTENCY_STALE_AFTER_MS=300000
EVENT_DISPATCH_BATCH_SIZE=100
EVENT_DISPATCH_MAX_ATTEMPTS=10
EVENT_READINESS_MAX_PENDING=5000
EVENT_READINESS_MAX_DEAD_LETTERS=0
SLO_EVENT_LAG_WARN_SECONDS=30
SLO_EVENT_LAG_CRITICAL_SECONDS=120
SLO_ERROR_LOG_WARN_COUNT=10
SLO_POOL_WAITING_WARN_COUNT=1

# Private object storage and malware scanning
ASSET_STORAGE_PROVIDER=local
ASSET_STORAGE_BUCKET=
ASSET_STORAGE_REGION=us-east-1
ASSET_STORAGE_ENDPOINT=
ASSET_STORAGE_FORCE_PATH_STYLE=false
ASSET_ACCESS_MODE=signed-url
ASSET_SIGNED_URL_TTL_SECONDS=300
ASSET_S3_KMS_KEY_ID=
# Development-only escape hatch for S3-compatible stores without a local KMS.
# Production still requires ASSET_S3_KMS_KEY_ID.
ASSET_STORAGE_ENCRYPTION=
ASSET_SCANNER_URL=
ASSET_SCANNER_API_KEY=
ASSET_SCANNER_TIMEOUT_MS=15000
ASSET_RETENTION_DAYS=
AUDIT_ARCHIVE_BUCKET=
AUDIT_ARCHIVE_RETENTION_DAYS=2557
